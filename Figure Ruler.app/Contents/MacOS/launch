#!/bin/bash
# Figure Ruler launcher.
# Opens the tool directly in the default browser (file://). No local server — the
# browser reads the file with its own permissions, which sidesteps the macOS privacy
# (TCC) block that prevents an unsigned app from serving files inside a Desktop folder.
SELF="$0"
while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
ROOT="$(cd "$(dirname "$SELF")/../../.." && pwd)"   # → figure-ruler/
open "$ROOT/figure_ruler.html"
